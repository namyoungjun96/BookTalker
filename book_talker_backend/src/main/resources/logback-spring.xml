<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds">

    <springProperty scope="context" name="DISCORD_WEBHOOK_URL"
                    source="app.discord.webhook-url" defaultValue=""/>

    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Seoul} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="LOG_PATH"      value="./logs"/>
    <property name="LOG_FILE_NAME" value="booktalker"/>

    <!-- ── Console (local 전용) ── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── File: 전체 로그 (공통) ── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>100</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ── File: ERROR 전용 (prod) ── -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${LOG_FILE_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${LOG_FILE_NAME}-error.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>100</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ── Discord Webhook: ERROR 전용 (prod) ── -->
    <appender name="DISCORD"
              class="com.example.book_talker_backend.config.DiscordWebhookAppender">
        <webhookUrl>${DISCORD_WEBHOOK_URL}</webhookUrl>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- ── 공통 logger ── -->
    <logger name="org.springframework" level="WARN"/>

    <!-- ── local 프로파일 ── -->
    <springProfile name="local">
        <logger name="com.example.book_talker_backend" level="DEBUG"/>
        <logger name="org.hibernate.SQL"               level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- ── prod 프로파일 ── -->
    <springProfile name="prod">
        <logger name="com.example.book_talker_backend" level="INFO"/>
        <logger name="org.hibernate.SQL"               level="WARN"/>
        <root level="INFO">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
            <appender-ref ref="DISCORD"/>
        </root>
    </springProfile>

</configuration>
